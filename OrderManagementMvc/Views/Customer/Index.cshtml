@model IEnumerable<OrderManagementMvc.Models.Customer>

@{
    ViewData["Title"] = "Customer";
}

<h2>Customers</h2>

<a asp-action="Create" class="Customers">New Customer</a> 

<table class="table table-striped">
    <thead> 
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Telefone</th>
            <th>Cpf</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var customer in Model)
        {
            <tr>
                <td>@customer.Name</td>
                <td>@customer.Email</td>
                <td>@customer.Telefone</td>
                <td>@customer.Cpf</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@customer.Id" class="btn btn-primary">
                        Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@customer.Id" class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>